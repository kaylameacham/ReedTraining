# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Sigma API credentials (Admin > APIs & Embed Secrets in Sigma)
SIGMA_CLIENT_ID=your_client_id_here
SIGMA_CLIENT_SECRET=your_client_secret_here

# Base URL — pick the one matching your Sigma cloud region:
#   AWS US:     https://aws-api.sigmacomputing.com
#   AWS Canada: https://api.ca.aws.sigmacomputing.com
#   Azure:      https://api.azure.sigmacomputing.com
#   GCP:        https://api.gcp.sigmacomputing.com
SIGMA_BASE_URL=https://aws-api.sigmacomputing.com
